  m_Name: 
  m_EditorClassIdentifier: 
  panelRoot: {fileID: 1877897494}
  questionText: {fileID: 1651929776}
  question: Now, look at those appliances on the floor. The floodwater will destroy
    them and they could still be a hazard. What should you do?
  answerButtonA: {fileID: 1672591456}
  answerButtonB: {fileID: 972007916}
  answerButtonC: {fileID: 531796765}
  answerTextA: {fileID: 1745929230}
  answerTextB: {fileID: 1183711172}
  answerTextC: {fileID: 80395425}
  questionsPanel: {fileID: 975103647}
  answerA: A. Unplug them and move them to a high shelf or the second floor.
  answerB: B. Cover them with a plastic bag.
  answerC: C. Do nothing, the power is off.
  answerImageA: {fileID: 0}
  answerImageB: {fileID: 0}
  answerImageC: {fileID: 0}
  confirmButton: {fileID: 235894861}
  feedbackPanel: {fileID: 1758240295}
